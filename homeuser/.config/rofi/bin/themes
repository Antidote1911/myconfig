#!/bin/bash

## Author : Aditya Shakya (adi1090x)
## Mail : adi1090x@gmail.com
## Github : @adi1090x
## Reddit : @adi1090x

DIR="$HOME/.config"
XDIR="$HOME/.Xresources.d"

rofi_command="rofi -theme $DIR/rofi/styles/themes.rasi"

style (){
	cat "$DIR"/themes/$1 > "$XDIR"/colors
	nitrogen --set-zoom-fill --save /usr/share/backgrounds/$1.jpg
        betterlockscreen -u /usr/share/backgrounds/$1.jpg
	bspc wm -r
}

# Apps
theme_1="Ó•ö Nord"
theme_2="Ó•ö Forest"
theme_3="Ó•ö Packarch"
theme_4="Ó•ö Cyberpunk"
theme_5="Ó•ö Groot"
theme_6="Ó•ö Rick"
theme_7="Ó•ö Matrix"

# Variable passed to rofi
options="$theme_1\n$theme_2\n$theme_3\n$theme_4\n$theme_5\n$theme_6\n$theme_7"

chosen="$(echo -e "$options" | $rofi_command -p "Available themes" -dmenu -selected-row 0)"
case $chosen in
    $theme_1)
        style nord
        ;;
    $theme_2)
        style forest
        ;;
    $theme_3)
        style packarch
        ;;
    $theme_4)
        style cyberpunk
        ;;
    $theme_5)
        style groot
        ;;
    $theme_6)
        style rick
        ;;
    $theme_7)
        style matrix
        ;;
esac

